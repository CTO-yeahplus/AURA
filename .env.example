# 대기자 폼 발송용 Resend API 키 (Vercel 환경변수에 설정 — 앱/깃에 커밋 금지)
# Resend 대시보드 → API Keys 에서 발급. 발신 도메인 auraootd.com 이 Resend에서 인증돼 있어야 함.
RESEND_API_KEY=

# 홈피드 라이브 룩(/ootd)용 Supabase 공개 읽기. 앱 .env의 EXPO_PUBLIC_* 와 동일 값.
# anon 키는 publishable(공개용) — looks/products는 public read(RLS)라 안전. Vercel 환경변수에 설정.
NEXT_PUBLIC_SUPABASE_URL=https://zofydqjyfzvyusbkllan.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
